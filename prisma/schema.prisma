generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id            String    @id @default(cuid())
  name          String
  designation   String
  tagline       String?
  bio           String
  email         String
  phone         String?
  whatsapp      String?
  resumeUrl     String?
  photoUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  socialLinks   SocialLink[]
  skills        Skill[]
  education     Education[]
  experience    Experience[]
  projects      Project[]
}

model SocialLink {
  id        String  @id @default(cuid())
  platform  String
  url       String
  icon      String?
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SkillCategory {
  id    String  @id @default(cuid())
  name  String  @unique
  skills Skill[]
}

model Skill {
  id           String        @id @default(cuid())
  name         String
  level        Int           @default(0)
  icon         String?
  profileId    String
  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     SkillCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  description String?
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String?
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
  id              String       @id @default(cuid())
  title           String
  description     String
  longDescription String?
  imageUrl        String?
  liveUrl         String?
  githubUrl       String?
  techStack       String[]
  challenges      String?
  improvements    String?
  featured        Boolean      @default(false)
  profileId       String
  profile         Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  images          ProjectImage[]
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
